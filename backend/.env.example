# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/blood-donor-db
MONGODB_URI=mongodb://localhost:27017/blood-donor-db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Google OAuth 2.0 (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Nodemailer - e.g. Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Blood Donor System <noreply@blooddonor.com>"

# Admin (for seed script - use this email with Google to get admin access)
ADMIN_EMAIL=admin@blooddonor.local

# Optional external maps/geocoding provider
MAPS_API_KEY=your-google-maps-api-key

# Matching engine
INITIAL_RADIUS_KM=30
MAX_RADIUS_KM=250
ESCALATION_RADIUS_STEP_KM=25
TOP_DONORS_TO_NOTIFY=3
RESPONSE_TIMEOUT_MINUTES=15
CRITICAL_RESPONSE_TIMEOUT_MINUTES=7
CRITICAL_ESCALATION_BATCH_SIZE=5

# Medical waiting periods
BLOOD_WAITING_PERIOD_DAYS=56
ORGAN_WAITING_PERIOD_DAYS=180

# Security and abuse detection
REQUEST_CREATION_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_MAX=25
API_RATE_LIMIT_MAX=250
LOCATION_MISMATCH_THRESHOLD_KM=250

# Background workers
REQUEST_ESCALATION_INTERVAL_MS=60000
DONOR_AVAILABILITY_JOB_INTERVAL_MS=3600000
